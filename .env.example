# GiljoAI MCP Environment Configuration
# Copy this file to .env and update with your values
# NEVER commit .env to version control!

# =============================================================================
# PORT CONFIGURATION (v2.0 Unified Architecture)
# =============================================================================
# Main API Server Port (handles API + WebSocket + MCP tools)
GILJO_API_PORT=7272
GILJO_PORT=7272  # Alias for GILJO_API_PORT

# Frontend Development Server Port
GILJO_FRONTEND_PORT=6000
VITE_FRONTEND_PORT=6000

# PostgreSQL Database Port
POSTGRES_PORT=5432
DB_PORT=5432

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_TYPE=postgresql
DB_HOST=localhost
DB_NAME=giljo_mcp
DB_USER=postgres
DB_PASSWORD=your_password_here

# Alternative: Full database URL (overrides individual settings)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/giljo_mcp

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Deployment mode: LOCAL, LAN, or WAN
GILJO_MCP_MODE=LOCAL

# API Host (0.0.0.0 for network access, 127.0.0.1 for localhost only)
GILJO_API_HOST=127.0.0.1

# =============================================================================
# SECURITY
# =============================================================================
# API Key for authentication (required for LAN/WAN modes)
GILJO_MCP_API_KEY=

# Secret key for session management
GILJO_MCP_SECRET_KEY=

# MCP Installer Secret (for share link token generation)
MCP_INSTALLER_SECRET_KEY=your-secret-key-here

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# API URL for frontend (usually http://localhost:${GILJO_API_PORT})
VITE_API_URL=http://localhost:7272
# For HTTPS: VITE_API_URL=https://yourdomain.com:7272

# WebSocket URL (same as API in v2.0)
VITE_WS_URL=ws://localhost:7272
# For HTTPS: VITE_WS_URL=wss://yourdomain.com:7272

# App mode
VITE_APP_MODE=local

# API port for frontend
VITE_API_PORT=7272

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins or JSON array
CORS_ORIGINS=http://localhost:*

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=./logs/giljo_mcp.log
DEBUG=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_VISION_CHUNKING=true
ENABLE_MULTI_TENANT=true
ENABLE_WEBSOCKET=true
ENABLE_AUTO_HANDOFF=true
ENABLE_DYNAMIC_DISCOVERY=true

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
MAX_AGENTS_PER_PROJECT=20
AGENT_CONTEXT_LIMIT=150000
AGENT_HANDOFF_THRESHOLD=140000

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
SESSION_TIMEOUT=3600
MAX_CONCURRENT_SESSIONS=10
SESSION_CLEANUP_INTERVAL=300

# =============================================================================
# MESSAGE QUEUE CONFIGURATION
# =============================================================================
MAX_QUEUE_SIZE=1000
MESSAGE_BATCH_SIZE=10
MESSAGE_RETRY_ATTEMPTS=3
MESSAGE_RETRY_DELAY=1.0

# =============================================================================
# DOCKER BUILD CONFIGURATION
# =============================================================================
BUILD_TARGET=production

# =============================================================================
# ACTIVE PRODUCT (for MCP server context)
# =============================================================================
ACTIVE_PRODUCT=GiljoAI-MCP Coding Orchestrator

# =============================================================================
# SSL Configuration (optional - config.yaml is preferred)
# =============================================================================
# SSL_CERT_FILE=./certs/ssl_cert.pem
# SSL_KEY_FILE=./certs/ssl_key.pem
