[Unit]
Description=GiljoAI MCP Application Service
Documentation=https://github.com/GiljoAI/giljo-mcp
After=network.target postgresql.service redis.service
Wants=postgresql.service redis.service
Requires=network.target

[Service]
Type=simple
User=giljo
Group=giljo
WorkingDirectory=/home/giljo/.giljo_mcp

# Main application command
ExecStart=/usr/bin/python3 -m src.giljo_mcp.server

# Restart policy
Restart=always
RestartSec=10
StartLimitInterval=60
StartLimitBurst=5

# Environment variables
Environment="GILJO_CONFIG_DIR=/home/giljo/.giljo_mcp/config"
Environment="GILJO_DATA_DIR=/home/giljo/.giljo_mcp/data"
Environment="GILJO_LOG_DIR=/home/giljo/.giljo_mcp/logs"
Environment="PYTHONPATH=/home/giljo/.giljo_mcp"

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=giljo-mcp

# Security settings
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/home/giljo/.giljo_mcp

# Process limits
LimitNOFILE=1024
LimitNPROC=512

# Memory and CPU limits (optional)
MemoryMax=1G
CPUQuota=50%

# Timeout settings
TimeoutStartSec=60
TimeoutStopSec=30

# PID file
PIDFile=/home/giljo/.giljo_mcp/run/giljo-app.pid

[Install]
WantedBy=multi-user.target

