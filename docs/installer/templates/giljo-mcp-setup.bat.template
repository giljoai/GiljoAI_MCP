@echo off
REM ============================================================
REM GiljoAI MCP Tool Integration Installer
REM Generated for: {organization}
REM User: {username}
REM Server: {server_url}
REM Generated: {timestamp}
REM ============================================================

setlocal enabledelayedexpansion

REM Configuration Variables
set GILJO_SERVER={server_url}
set GILJO_API_KEY={api_key}
set GILJO_USER={username}
set GILJO_ORG={organization}

REM Tool Detection Results
set CLAUDE_CONFIGURED=
set CURSOR_CONFIGURED=
set WINDSURF_CONFIGURED=

REM Color output not supported in batch, using text markers instead
echo.
echo ============================================================
echo   GiljoAI MCP - Tool Integration Installer
echo ============================================================
echo.
echo This script will detect your development tools and configure
echo them to use GiljoAI Agent Orchestration MCP Server.
echo.
echo Server: %GILJO_SERVER%
echo User: %GILJO_USER%
echo Organization: %GILJO_ORG%
echo.
echo The script will:
echo   1. Detect Claude Code, Cursor, and Windsurf installations
echo   2. Create backups of existing configurations
echo   3. Safely merge GiljoAI MCP server configuration
echo   4. Preserve all existing tool settings
echo.
pause

echo.
echo ============================================================
echo   Scanning for Development Tools...
echo ============================================================
echo.

REM ============================================================
REM Detect and Configure Claude Code
REM ============================================================
set CLAUDE_CONFIG=%APPDATA%\.claude.json
if exist "%CLAUDE_CONFIG%" (
    echo [FOUND] Claude Code: %CLAUDE_CONFIG%
    call :configure_claude
) else (
    echo [SKIP]  Claude Code not detected
)

REM ============================================================
REM Detect and Configure Cursor
REM ============================================================
set CURSOR_DIR=%APPDATA%\Cursor\User\globalStorage
set CURSOR_CONFIG=%CURSOR_DIR%\mcp.json
if exist "%CURSOR_DIR%" (
    echo [FOUND] Cursor: %CURSOR_CONFIG%
    call :configure_cursor
) else (
    echo [SKIP]  Cursor not detected
)

REM ============================================================
REM Detect and Configure Windsurf
REM ============================================================
set WINDSURF_DIR=%APPDATA%\Windsurf
set WINDSURF_CONFIG=%WINDSURF_DIR%\config.json
if exist "%WINDSURF_DIR%" (
    echo [FOUND] Windsurf: %WINDSURF_CONFIG%
    call :configure_windsurf
) else (
    echo [SKIP]  Windsurf not detected
)

REM ============================================================
REM Configuration Summary
REM ============================================================
echo.
echo ============================================================
echo   Configuration Complete!
echo ============================================================
echo.

set TOOL_COUNT=0
if defined CLAUDE_CONFIGURED (
    echo [OK] Claude Code configured successfully
    set /a TOOL_COUNT+=1
)
if defined CURSOR_CONFIGURED (
    echo [OK] Cursor configured successfully
    set /a TOOL_COUNT+=1
)
if defined WINDSURF_CONFIGURED (
    echo [OK] Windsurf configured successfully
    set /a TOOL_COUNT+=1
)

if %TOOL_COUNT%==0 (
    echo.
    echo [WARNING] No development tools were detected or configured.
    echo.
    echo Please ensure you have one of the following installed:
    echo   - Claude Code ^(AI CLI by Anthropic^)
    echo   - Cursor ^(AI Code Editor^)
    echo   - Windsurf ^(Codeium AI IDE^)
    echo.
    echo After installation, run this script again.
) else (
    echo.
    echo Successfully configured %TOOL_COUNT% tool^(s^).
    echo.
    echo Server: %GILJO_SERVER%
    echo User: %GILJO_USER%
    echo.
    echo ============================================================
    echo   IMPORTANT: Please restart your development tools
    echo   for the changes to take effect.
    echo ============================================================
)

echo.
pause
endlocal
exit /b 0

REM ============================================================
REM Function: Configure Claude Code
REM ============================================================
:configure_claude
    echo   Configuring Claude Code...

    REM Create timestamped backup
    for /f "tokens=2-4 delims=/ " %%a in ('date /t') do (set BACKUP_DATE=%%c%%a%%b)
    for /f "tokens=1-2 delims=/: " %%a in ('time /t') do (set BACKUP_TIME=%%a%%b)
    set BACKUP_FILE=%CLAUDE_CONFIG%.backup.%BACKUP_DATE%.%BACKUP_TIME%

    echo   Creating backup: %BACKUP_FILE%
    copy "%CLAUDE_CONFIG%" "%BACKUP_FILE%" >nul 2>&1
    if errorlevel 1 (
        echo   [ERROR] Failed to create backup
        goto :eof
    )

    REM Use PowerShell to safely merge JSON configuration
    powershell -NoProfile -ExecutionPolicy Bypass -Command ^
        "$ErrorActionPreference='Stop'; ^
        try { ^
            $configPath = '%CLAUDE_CONFIG%'; ^
            $config = if (Test-Path $configPath) { ^
                Get-Content $configPath -Raw -Encoding UTF8 | ConvertFrom-Json ^
            } else { ^
                @{} ^
            }; ^
            if (-not $config.PSObject.Properties['mcpServers']) { ^
                $config | Add-Member -Type NoteProperty -Name mcpServers -Value @{} -Force ^
            }; ^
            $config.mcpServers.'giljo-mcp' = @{ ^
                command = 'python'; ^
                args = @('-m', 'giljo_mcp.mcp_adapter'); ^
                env = @{ ^
                    GILJO_SERVER_URL = '%GILJO_SERVER%'; ^
                    GILJO_API_KEY = '%GILJO_API_KEY%' ^
                } ^
            }; ^
            $json = $config | ConvertTo-Json -Depth 10; ^
            [System.IO.File]::WriteAllText($configPath, $json, [System.Text.Encoding]::UTF8); ^
            exit 0 ^
        } catch { ^
            Write-Error $_.Exception.Message; ^
            exit 1 ^
        }"

    if errorlevel 1 (
        echo   [ERROR] Failed to configure Claude Code
        echo   [INFO]  Backup preserved at: %BACKUP_FILE%
    ) else (
        echo   [OK]    Claude Code configured successfully
        set CLAUDE_CONFIGURED=1
    )
    goto :eof

REM ============================================================
REM Function: Configure Cursor
REM ============================================================
:configure_cursor
    echo   Configuring Cursor...

    REM Create directory if it doesn't exist
    if not exist "%CURSOR_DIR%" (
        echo   Creating Cursor config directory...
        mkdir "%CURSOR_DIR%" 2>nul
    )

    REM Create timestamped backup if config exists
    if exist "%CURSOR_CONFIG%" (
        for /f "tokens=2-4 delims=/ " %%a in ('date /t') do (set BACKUP_DATE=%%c%%a%%b)
        for /f "tokens=1-2 delims=/: " %%a in ('time /t') do (set BACKUP_TIME=%%a%%b)
        set BACKUP_FILE=%CURSOR_CONFIG%.backup.%BACKUP_DATE%.%BACKUP_TIME%

        echo   Creating backup: %BACKUP_FILE%
        copy "%CURSOR_CONFIG%" "%BACKUP_FILE%" >nul 2>&1
        if errorlevel 1 (
            echo   [ERROR] Failed to create backup
            goto :eof
        )
    )

    REM Use PowerShell to safely merge JSON configuration
    powershell -NoProfile -ExecutionPolicy Bypass -Command ^
        "$ErrorActionPreference='Stop'; ^
        try { ^
            $configPath = '%CURSOR_CONFIG%'; ^
            $config = if (Test-Path $configPath) { ^
                Get-Content $configPath -Raw -Encoding UTF8 | ConvertFrom-Json ^
            } else { ^
                @{} ^
            }; ^
            if (-not $config.PSObject.Properties['mcpServers']) { ^
                $config | Add-Member -Type NoteProperty -Name mcpServers -Value @{} -Force ^
            }; ^
            $config.mcpServers.'giljo-mcp' = @{ ^
                command = 'python'; ^
                args = @('-m', 'giljo_mcp.mcp_adapter'); ^
                env = @{ ^
                    GILJO_SERVER_URL = '%GILJO_SERVER%'; ^
                    GILJO_API_KEY = '%GILJO_API_KEY%' ^
                } ^
            }; ^
            $json = $config | ConvertTo-Json -Depth 10; ^
            [System.IO.File]::WriteAllText($configPath, $json, [System.Text.Encoding]::UTF8); ^
            exit 0 ^
        } catch { ^
            Write-Error $_.Exception.Message; ^
            exit 1 ^
        }"

    if errorlevel 1 (
        echo   [ERROR] Failed to configure Cursor
        if exist "%BACKUP_FILE%" (
            echo   [INFO]  Backup preserved at: %BACKUP_FILE%
        )
    ) else (
        echo   [OK]    Cursor configured successfully
        set CURSOR_CONFIGURED=1
    )
    goto :eof

REM ============================================================
REM Function: Configure Windsurf
REM ============================================================
:configure_windsurf
    echo   Configuring Windsurf...

    REM Create directory if it doesn't exist
    if not exist "%WINDSURF_DIR%" (
        echo   Creating Windsurf config directory...
        mkdir "%WINDSURF_DIR%" 2>nul
    )

    REM Create timestamped backup if config exists
    if exist "%WINDSURF_CONFIG%" (
        for /f "tokens=2-4 delims=/ " %%a in ('date /t') do (set BACKUP_DATE=%%c%%a%%b)
        for /f "tokens=1-2 delims=/: " %%a in ('time /t') do (set BACKUP_TIME=%%a%%b)
        set BACKUP_FILE=%WINDSURF_CONFIG%.backup.%BACKUP_DATE%.%BACKUP_TIME%

        echo   Creating backup: %BACKUP_FILE%
        copy "%WINDSURF_CONFIG%" "%BACKUP_FILE%" >nul 2>&1
        if errorlevel 1 (
            echo   [ERROR] Failed to create backup
            goto :eof
        )
    )

    REM Use PowerShell to safely merge JSON configuration
    powershell -NoProfile -ExecutionPolicy Bypass -Command ^
        "$ErrorActionPreference='Stop'; ^
        try { ^
            $configPath = '%WINDSURF_CONFIG%'; ^
            $config = if (Test-Path $configPath) { ^
                Get-Content $configPath -Raw -Encoding UTF8 | ConvertFrom-Json ^
            } else { ^
                @{} ^
            }; ^
            if (-not $config.PSObject.Properties['mcpServers']) { ^
                $config | Add-Member -Type NoteProperty -Name mcpServers -Value @{} -Force ^
            }; ^
            $config.mcpServers.'giljo-mcp' = @{ ^
                command = 'python'; ^
                args = @('-m', 'giljo_mcp.mcp_adapter'); ^
                env = @{ ^
                    GILJO_SERVER_URL = '%GILJO_SERVER%'; ^
                    GILJO_API_KEY = '%GILJO_API_KEY%' ^
                } ^
            }; ^
            $json = $config | ConvertTo-Json -Depth 10; ^
            [System.IO.File]::WriteAllText($configPath, $json, [System.Text.Encoding]::UTF8); ^
            exit 0 ^
        } catch { ^
            Write-Error $_.Exception.Message; ^
            exit 1 ^
        }"

    if errorlevel 1 (
        echo   [ERROR] Failed to configure Windsurf
        if exist "%BACKUP_FILE%" (
            echo   [INFO]  Backup preserved at: %BACKUP_FILE%
        )
    ) else (
        echo   [OK]    Windsurf configured successfully
        set WINDSURF_CONFIGURED=1
    )
    goto :eof
