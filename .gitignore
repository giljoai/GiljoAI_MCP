# ============================================================================
# .gitignore - Standard Development Environment
# ============================================================================
# This file follows Python/Node.js best practices for version control.
# All development files should be committed to GitHub.
# For release file filtering, see: giltest.ignore.md
# ============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
.venv/
uv.lock
env/
ENV/
env.bak/
venv.bak/
dev_tools/venv_devtools/
dev_tools/devtools.local.ini

# Testing - Python
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

