# ============================================================================
# .gitignore - Standard Development Environment
# ============================================================================
# This file follows Python/Node.js best practices for version control.
# All development files should be committed to GitHub.
# For release file filtering, see: giltest.ignore.md
# ============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
dev_tools/venv_devtools/  # Isolated venv for dev tools only

# Testing - Python
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Testing - Frontend (Vitest)
frontend/coverage/

# Testing - Playwright (E2E)
frontend/playwright-report/
frontend/test-results/
playwright-report/
test-results/
playwright/.cache/
.playwright/

# Type Checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Linting
.ruff_cache/

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Claude and Serena (AI assistants)
.claude/
!.claude/commands/  # Track project-level slash commands
.serena/
serena/

# Logs
*.log
logs/
*.log.*

# Database
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# Environment Variables (sensitive data)
.env
.env.local
.env.*.local

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Frontend build output (generated)
frontend/dist/
frontend/.nuxt/
frontend/.output/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup
*.swp
*.swo

# OS-specific
Thumbs.db
.DS_Store
desktop.ini

# Project-specific runtime data
data/giljo_mcp.db
uploads/
runtime/
products/
backups/*.backup

# SSL certificates (never commit private keys)
*.key
*.pem
certs/*.key
certs/*.pem

# API keys and secrets
api_keys.json
secrets.json
credentials.json

# User-specific config (should use .example templates)
config.yaml
install_config.yaml
.mcp.json

# Claude Code configuration (system-specific)
CLAUDE.md
.claude.json
.claude/

# Serena MCP configuration (system-specific)
.serena/
serena/
cleanup_auto.ps1
cleanup_for_fresh_install.ps1
IMPORTANT.txt
.aider*
external/serena-venv/bin/python
external/serena-venv/bin/python3
external/serena-venv/bin/python3.12
external/serena-venv/lib64
external/serena-venv/pyvenv.cfg
external/serena/

# Installer credentials (generated during setup, contain passwords)
installer/credentials/

# Archives (cleanup items, not for version control)
docs/archive/0130_websocket_v1_backups/
handovers/Project_500_Prompt.md
backup*.sql
tmpclaude-e682-cwd
tmpclaude-787f-cwd
*.dump
*.0
setup_test_report.json
setup_test_report.json
CLAUDE.md
nul
