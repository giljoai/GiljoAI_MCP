# =============================================================================
# GiljoAI MCP - Claude Code Web (CCW) Environment Configuration
# =============================================================================
# This .env is optimized for Claude Code Web remote environment
# CCW cannot access local database or MCP servers
# Focus: Frontend, API logic, docs, pure Python utilities
# =============================================================================

# =============================================================================
# PROJECT CONTEXT (for AI agents)
# =============================================================================
PROJECT_NAME=GiljoAI-MCP
PROJECT_VERSION=3.1.0
PROJECT_TYPE=multi_tenant_agent_orchestration
TECH_STACK=Python3.11+FastAPI+PostgreSQL+Vue3+Vuetify

# Active product context
ACTIVE_PRODUCT=GiljoAI-MCP Coding Orchestrator

# Architecture version (important for understanding codebase)
ARCHITECTURE_VERSION=v3.0_unified_single_active_product

# =============================================================================
# DEVELOPMENT ENVIRONMENT FLAGS
# =============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
CLAUDE_CODE_REMOTE=true

# CCW-specific: Skip operations requiring local resources
SKIP_DB_CONNECTION=true
SKIP_MCP_REGISTRATION=true
MOCK_DATABASE=true

# =============================================================================
# PORT CONFIGURATION (reference only - CCW can't bind to these)
# =============================================================================
# Main API Server Port
GILJO_API_PORT=7272
GILJO_PORT=7272

# Frontend Dev Server Port
GILJO_FRONTEND_PORT=7274
VITE_FRONTEND_PORT=7274

# PostgreSQL Port (localhost only)
POSTGRES_PORT=5432
DB_PORT=5432

# =============================================================================
# DATABASE CONFIGURATION (reference only - no actual connection in CCW)
# =============================================================================
DB_TYPE=postgresql
DB_HOST=localhost
DB_NAME=giljo_mcp
DB_USER=giljo_user
# Note: Actual password in local .env (gitignored)

# =============================================================================
# FRONTEND CONFIGURATION (for Vue/Vite builds)
# =============================================================================
# API URL for frontend (localhost reference)
VITE_API_URL=http://localhost:7272
VITE_WS_URL=ws://localhost:7272
VITE_APP_MODE=development
VITE_API_PORT=7272

# Node/npm settings
NODE_ENV=development
NODE_OPTIONS=--max-old-space-size=4096

# =============================================================================
# PYTHON ENVIRONMENT
# =============================================================================
PYTHONPATH=/workspace/src:/workspace
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
# Pytest settings
PYTEST_TIMEOUT=300
PYTEST_WORKERS=auto
TEST_COVERAGE_MIN=80

# Testing database (mock in CCW)
TEST_DB_NAME=giljo_mcp_test
TEST_DB_USER=test_user

# Skip tests requiring live database
SKIP_INTEGRATION_TESTS=true
SKIP_DB_TESTS=true
RUN_UNIT_TESTS_ONLY=true

# =============================================================================
# CODE QUALITY TOOLS
# =============================================================================
# Ruff (Python linting)
RUFF_CACHE_DIR=/tmp/ruff_cache
RUFF_FORMAT=json

# Black (Python formatting)
BLACK_LINE_LENGTH=100

# ESLint (JavaScript/Vue linting)
ESLINT_USE_FLAT_CONFIG=true

# =============================================================================
# FEATURE FLAGS (all features - CCW needs to understand full architecture)
# =============================================================================
# Core features
ENABLE_VISION_CHUNKING=true
ENABLE_MULTI_TENANT=true
ENABLE_WEBSOCKET=true
ENABLE_AUTO_HANDOFF=true
ENABLE_DYNAMIC_DISCOVERY=true

# Security features (always enabled in v3.0)
ENABLE_AUTHENTICATION=true
ENABLE_AUTO_LOGIN_LOCALHOST=true
ENABLE_SSL=false

# v3.0 Architecture features
SINGLE_ACTIVE_PRODUCT=true
SINGLE_ACTIVE_PROJECT_PER_PRODUCT=true
PROJECT_SOFT_DELETE=true
ORCHESTRATOR_SUCCESSION=true

# =============================================================================
# AGENT CONFIGURATION (reference for understanding orchestration)
# =============================================================================
MAX_AGENTS_PER_PROJECT=20
AGENT_CONTEXT_LIMIT=150000
AGENT_HANDOFF_THRESHOLD=140000

# Orchestrator succession
SUCCESSION_CONTEXT_THRESHOLD=0.90
HANDOVER_SUMMARY_MAX_TOKENS=10000

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
SESSION_TIMEOUT=3600
MAX_CONCURRENT_SESSIONS=10
SESSION_CLEANUP_INTERVAL=300

# =============================================================================
# MESSAGE QUEUE CONFIGURATION
# =============================================================================
MAX_QUEUE_SIZE=1000
MESSAGE_BATCH_SIZE=10
MESSAGE_RETRY_ATTEMPTS=3
MESSAGE_RETRY_DELAY=1.0

# =============================================================================
# PATHS (CCW workspace paths - not F:\ paths)
# =============================================================================
DATA_DIR=/workspace/data
LOGS_DIR=/workspace/logs
UPLOAD_DIR=/workspace/uploads
TEMP_DIR=/workspace/temp

# Frontend paths
FRONTEND_DIR=/workspace/frontend
FRONTEND_DIST=/workspace/frontend/dist

# Backend paths
BACKEND_DIR=/workspace/api
CORE_DIR=/workspace/src/giljo_mcp

# =============================================================================
# GIT CONFIGURATION (for CCW branch workflow)
# =============================================================================
# CCW creates feature branches automatically
GIT_DEFAULT_BRANCH=master
GIT_AUTHOR_NAME=Claude Code Web
GIT_AUTHOR_EMAIL=ccw@giljoai.local

# =============================================================================
# PERFORMANCE & RESOURCE LIMITS
# =============================================================================
WORKER_COUNT=1
CONNECTION_POOL_SIZE=5

# Build performance
VITE_BUILD_CHUNK_SIZE_LIMIT=2000
VITE_OPTIMIZE_DEPS=true

# =============================================================================
# CCW-SPECIFIC: TASK CATEGORIZATION
# =============================================================================
# These help CCW agents understand what work is safe to do

# Safe for CCW (no DB/local resources needed)
CCW_SAFE_TASKS=frontend,docs,api_logic,utils,tests_unit

# Requires local CLI (database/system access)
CLI_ONLY_TASKS=db_migrations,db_queries,integration_tests,mcp_tools,installer

# Sequential only (avoid parallel execution)
CCW_SEQUENTIAL_TASKS=db_models,templates,api_mutations

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================
BUILD_TARGET=development

# Frontend build
VITE_BUILD_MINIFY=false
VITE_BUILD_SOURCEMAP=true

# Docker (not used in CCW but referenced in codebase)
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# =============================================================================
# CORS CONFIGURATION (reference for API development)
# =============================================================================
CORS_ORIGINS=http://localhost:*,http://127.0.0.1:*

# =============================================================================
# TEMPLATE SYSTEM (v3.0+)
# =============================================================================
# Use template_manager.py (NOT mission_templates.py - deprecated)
USE_TEMPLATE_MANAGER=true
TEMPLATE_CACHE_ENABLED=true
TEMPLATE_CACHE_TTL=3600

# Template resolution cascade
# 1. Product-specific → 2. Tenant-specific → 3. System default → 4. Legacy fallback

# =============================================================================
# THIN CLIENT ARCHITECTURE (v3.1+ Handover 0088)
# =============================================================================
# Use ThinClientPromptGenerator for 70% token reduction
USE_THIN_CLIENT_PROMPTS=true
THIN_CLIENT_MAX_TOKENS=10000

# Deprecated: OrchestratorPromptGenerator (remove in v4.0)
USE_FAT_PROMPTS=false

# =============================================================================
# HANDOVER WORKFLOW (Project 500 Series)
# =============================================================================
# Handover document location
HANDOVER_DIR=/workspace/handovers
HANDOVER_FORMAT_GUIDE=/workspace/handovers/HANDOVER_INSTRUCTIONS.md

# Completion criteria
HANDOVER_TEST_COVERAGE_MIN=80
HANDOVER_REQUIRE_TESTS=true
HANDOVER_REQUIRE_DOCS=true

# =============================================================================
# AI AGENT TOOLING (reference - not available in CCW)
# =============================================================================
# Serena MCP (CLI only - CCW doesn't support MCP)
SERENA_MCP_ENABLED=false
USE_SERENA_TOOLS=false

# Alternative: Use standard Read/Edit/Grep/Glob in CCW
USE_STANDARD_TOOLS=true

# Claude Code subagents (available in CCW)
USE_SUBAGENTS=true
SUBAGENT_TYPES=backend-tester,database-expert,tdd-implementor,frontend-tester

# =============================================================================
# DOCUMENTATION STANDARDS
# =============================================================================
# Token-efficient docs for AI agents (not verbose docstrings)
DOC_STYLE=ai_agent_optimized
DOC_MAX_LINES_PER_FUNCTION=5

# Examples:
# ✅ "ProductService.upload_vision() - Chunks docs <25K tokens"
# ❌ "This method uploads a vision document for the specified product..."

# =============================================================================
# QUALITY GATES
# =============================================================================
# Production-grade code only (no TODOs, no bandaids)
ALLOW_TODO_COMMENTS=false
ALLOW_PLACEHOLDER_CODE=false
REQUIRE_PRODUCTION_GRADE=true

# Cross-platform compliance
REQUIRE_PATHLIB=true
FORBID_HARDCODED_PATHS=true

# =============================================================================
# LOGGING (CCW environment)
# =============================================================================
LOG_FILE=/workspace/logs/giljo_mcp_ccw.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=3

# =============================================================================
# CCW SESSION INFO (populated by SessionStart hook)
# =============================================================================
# Automatically set by .claude/settings.json hook
# CCW_SESSION_ID=auto-generated
# CCW_BRANCH=feature/handover-XXXX
# CCW_STARTED_AT=timestamp

# =============================================================================
# TROUBLESHOOTING FLAGS
# =============================================================================
# Enable verbose output for debugging CCW-specific issues
VERBOSE_LOGGING=true
DEBUG_API_CALLS=false
DEBUG_FRONTEND_BUILD=false
DEBUG_TESTS=false

# Show warnings for CLI-only operations attempted in CCW
WARN_ON_DB_ACCESS=true
WARN_ON_MCP_CALLS=true

# =============================================================================
# NOTES FOR CCW AGENTS
# =============================================================================
# 1. No direct database access - all DB work must be merged and tested locally
# 2. No MCP servers (Serena) - use Read/Edit/Grep/Glob instead
# 3. Focus on: frontend, docs, API logic, pure Python utils
# 4. Avoid: DB migrations, integration tests, MCP tool dev, installer
# 5. Follow patterns in CLAUDE.md and handover docs
# 6. Production-grade code only - no TODOs or bandaids
# 7. Use pathlib.Path() for all file paths (cross-platform)
# 8. Token-efficient documentation style
# 9. Test coverage >80% required
# 10. Run `pytest tests/unit/` only (skip integration tests)
