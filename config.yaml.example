# GiljoAI MCP Orchestrator Configuration v2.0
# Copy this file to config.yaml and adjust settings as needed
# This configuration is production-ready with unified port architecture
#
# KEY CHANGES IN v2.0:
# - Single unified port (7272) for API, MCP tools, and WebSocket
# - PostgreSQL is now the recommended default database
# - Simplified configuration structure
# - Production-ready defaults for 15-day launch
#
# QUICK START:
# 1. Copy this file to config.yaml
# 2. Set your PostgreSQL password
# 3. Run: start_giljo.bat (Windows) or ./start_giljo.sh (Mac/Linux)
# 4. Access dashboard at: http://localhost:7272

# Database Configuration
database:
  # Database type: postgresql (recommended)
  database_type: postgresql

  # PostgreSQL configuration (required for production)
  host: localhost
  port: 5432
  name: giljo_mcp
  user: postgres
  password: ""  # Set your PostgreSQL password here


# Server Configuration - Unified v2.0 Architecture
server:
  # Mode: local (single user), lan (network), or wan (internet)
  mode: local
  host: localhost
  debug: false

  # Unified port for all services (API, MCP tools, WebSocket)
  port: 7272

  # Optional frontend development server port
  frontend_port: 7274

# Multi-Tenant Configuration
tenant:
  # Enable multi-tenant mode for enterprise deployments
  enable_multi_tenant: false

  # Default tenant key for single-tenant mode
  default_key: "dev-default-key"

  # Tenant key generation (for multi-tenant mode)
  # key_length: 48  # 192-bit entropy

# Application Configuration
app:
  name: "GiljoAI MCP Orchestrator"
  version: "1.0.0"

  # Directory paths (relative or absolute)
  data_dir: "./data"
  log_dir: "./logs"
  config_dir: "./config"

  # Vision document paths
  vision_dir: "./docs/Vision"

# Session Configuration
session:
  # Vision document chunking settings
  vision_chunk_size: 50000  # Characters per chunk
  vision_overlap: 1000      # Overlap between chunks
  context_size: 100000      # Maximum context size

  # Session timeout (seconds)
  timeout: 3600

# MCP Server Configuration
mcp:
  # Transport mode: stdio (default, used by Claude Code)
  stdio_mode: true
  transport: stdio

  # Note: v2.0 uses unified HTTP server at port 7272
  # MCP tools are exposed via HTTP endpoints, stdio adapter connects to them

# API Configuration
api:
  # CORS settings - adjust for your deployment
  cors_origins:
    - "http://localhost:7274"       # Frontend dev server
    - "http://localhost:7272"       # Main server
    - "http://127.0.0.1:7274"
    - "http://127.0.0.1:7272"

  # Rate limiting (requests per minute)
  rate_limit: 100

  # Authentication (enable for network deployments)
  require_api_key: false
  # api_key_header: "X-API-Key"

# WebSocket Configuration
websocket:
  # Heartbeat interval (seconds)
  heartbeat_interval: 30

  # Maximum connections per client
  max_connections: 10

  # Message queue size
  queue_size: 1000

# Logging Configuration
logging:
  # Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
  level: INFO

  # Log format
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"

  # Log file path
  file: "./logs/giljo.log"

  # Log rotation
  max_bytes: 10485760  # 10MB
  backup_count: 5

  # Console output
  console: true

# Agent Configuration
agents:
  # Maximum concurrent agents
  max_concurrent: 50

  # Agent timeout (seconds)
  timeout: 300

  # Default agent capabilities
  default_capabilities:
    - code_analysis
    - code_generation
    - testing
    - documentation

# Template Configuration
templates:
  # Template cache settings
  cache_enabled: true
  cache_ttl: 3600  # Seconds

  # Template generation performance target
  generation_target_ms: 0.1

# Security Configuration
security:
  # JWT settings
  jwt_secret_key: "CHANGE_THIS_IN_PRODUCTION"
  jwt_algorithm: "HS256"
  jwt_expiry: 86400  # 24 hours

  # Password requirements
  min_password_length: 12
  require_special_chars: true

  # Session security
  secure_cookies: false  # Set to true in production with HTTPS
  cookies:
    secure: false  # Set to true for HTTPS production deployments
  session_cookie_name: "giljo_session"

# Performance Configuration
performance:
  # Connection pooling
  db_pool_size: 20
  db_pool_overflow: 10

  # Caching
  enable_cache: true
  cache_backend: "memory"  # or "redis" for production

  # Request limits
  max_request_size: 10485760  # 10MB

# Development Configuration
development:
  # Hot reload
  auto_reload: true

  # Debug toolbar
  debug_toolbar: false

  # Profiling
  enable_profiling: false

# Production Configuration (uncomment for production)
# production:
#   # SSL/TLS
#   ssl_cert: "/path/to/cert.pem"
#   ssl_key: "/path/to/key.pem"
#
#   # Database connection pooling
#   db_pool_size: 50
#   db_pool_overflow: 20
#
#   # Redis cache
#   redis_url: "redis://localhost:6379/0"
#
#   # Monitoring
#   enable_metrics: true
#   metrics_port: 9090