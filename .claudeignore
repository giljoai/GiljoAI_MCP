# ============================================================================
# .claudeignore - Context Exclusions
# ============================================================================
# Prevents AI assistants from indexing cache folders, archives, and build artifacts
# This dramatically reduces context consumption and improves performance
# ============================================================================

# ============================================================================
# AI Assistant Caches & State (CRITICAL - 88MB+ savings)
# ============================================================================
.serena/
.serena/cache/
.claude/agents/
.aider*

# ============================================================================
# Python Caches & Build Artifacts
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Type checking & linting caches
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Testing caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/

# Build directories
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================================
# Package Manager Caches
# ============================================================================
.uv-cache/
pip-cache/
.npm/
.yarn/
.pnpm-store/

# ============================================================================
# Dependencies (CRITICAL - Large folders)
# ============================================================================
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
dev_tools/venv_devtools/
node_modules/
frontend/node_modules/

# ============================================================================
# Documentation Archives (357 files, 79k+ lines)
# ============================================================================
docs/archive/
**/*__FRAGMENTED.md
**/*__OUTDATED.md
**/*__URGENT.md
**/*__DEPRECATED.md

# ============================================================================
# Frontend Build Artifacts
# ============================================================================
frontend/dist/
frontend/.nuxt/
frontend/.output/
*.min.js
*.min.css
*.map
*.js.map
*.css.map

# ============================================================================
# Logs & Runtime Data
# ============================================================================
*.log
logs/
*.log.*
api/logs/
temp/
tmp/
*.tmp
*.bak
runtime/
uploads/
backups/*.backup

# ============================================================================
# Database Files
# ============================================================================
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
data/giljo_mcp.db

# ============================================================================
# Environment & Secrets (security)
# ============================================================================
.env
.env.local
.env.*.local
api_keys.json
secrets.json
credentials.json
*.key
*.pem
certs/*.key
certs/*.pem

# ============================================================================
# OS & IDE Files
# ============================================================================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ============================================================================
# Git & Version Control
# ============================================================================
.git/
.gitattributes

# ============================================================================
# Configuration (system-specific)
# ============================================================================
config.yaml
install_config.yaml
.mcp.json
.claude.json
cleanup_auto.ps1
cleanup_for_fresh_install.ps1
IMPORTANT.txt

# ============================================================================
# External Dependencies
# ============================================================================
external/serena-venv/
external/serena/
