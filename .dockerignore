# Root-level Docker build context ignore file
# Reduces build context when building from project root

# Python cache and compiled files
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/
htmlcov/
.tox/
.hypothesis/

# Virtual environments
venv/
ENV/
env/
.venv/
.virtualenv/

# Node modules and build artifacts
**/node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# IDE and editor files
.vscode/
.idea/
**/*.swp
**/*.swo
**/*~
**/.DS_Store
**/Thumbs.db
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# Git files
.git/
.gitignore
.gitattributes
.github/

# Documentation (except critical ones)
docs/
Docs/
*.md
!README.md
!CLAUDE.md

# Test files
tests/
test_*.py
*_test.py
test_results*.json
*test_results.json
coverage.xml
*.log

# Data and logs (will be volumes)
data/
logs/
temp/
backups/
*.db
*.sqlite
*.sqlite3

# Environment files (will be passed as env vars)
.env
.env.*
!.env.example
*.env

# Docker files
docker-compose*.yml
Dockerfile*

# CI/CD
.gitlab-ci.yml
.travis.yml
.circleci/

# Monitoring scripts
monitor*.py
benchmark*.py
*_monitor.py
*_benchmark.py
fix_*.py

# MCP configuration files
.mcp.json
.mcp-serena.json

# Claude-specific
.claude/
.serena/

# Keep only essential files for build
!api/
!src/
!frontend/src/
!frontend/public/
!frontend/package*.json
!frontend/index.html
!frontend/vite.config.js
!migrations/
!scripts/
!requirements.txt
!alembic.ini
!config.yaml
!setup.py