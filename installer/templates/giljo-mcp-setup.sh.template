#!/bin/bash
# ============================================================
# GiljoAI MCP Tool Integration Installer
# Generated for: {organization}
# User: {username}
# Server: {server_url}
# Generated: {timestamp}
# ============================================================

set -e  # Exit on error

# Configuration Variables
GILJO_SERVER="{server_url}"
GILJO_API_KEY="{api_key}"
GILJO_USER="{username}"
GILJO_ORG="{organization}"

# Tool Detection Results
CLAUDE_CONFIGURED=""
CURSOR_CONFIGURED=""
WINDSURF_CONFIGURED=""

# Color Output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Detect OS for platform-specific paths
OS_TYPE="$(uname -s)"
case "$OS_TYPE" in
    Darwin*)
        OS_NAME="macOS"
        CURSOR_BASE="$HOME/Library/Application Support/Cursor"
        WINDSURF_BASE="$HOME/Library/Application Support/Windsurf"
        ;;
    Linux*)
        OS_NAME="Linux"
        CURSOR_BASE="$HOME/.config/Cursor"
        WINDSURF_BASE="$HOME/.config/Windsurf"
        ;;
    *)
        OS_NAME="Unknown"
        CURSOR_BASE="$HOME/.config/Cursor"
        WINDSURF_BASE="$HOME/.config/Windsurf"
        ;;
esac

# ============================================================
# Helper Functions
# ============================================================

print_header() {
    echo ""
    echo "============================================================"
    echo "  $1"
    echo "============================================================"
    echo ""
}

print_status() {
    local status=$1
    local message=$2
    case "$status" in
        OK)
            echo -e "${GREEN}[OK]${NC}    $message"
            ;;
        ERROR)
            echo -e "${RED}[ERROR]${NC} $message"
            ;;
        FOUND)
            echo -e "${BLUE}[FOUND]${NC} $message"
            ;;
        SKIP)
            echo -e "${YELLOW}[SKIP]${NC}  $message"
            ;;
        INFO)
            echo -e "${BLUE}[INFO]${NC}  $message"
            ;;
    esac
}

check_dependencies() {
    # Check for jq (JSON processor)
    if ! command -v jq &> /dev/null; then
        print_status ERROR "jq is not installed. Please install jq to continue."
        echo ""
        echo "Installation instructions:"
        echo "  macOS:  brew install jq"
        echo "  Ubuntu: sudo apt-get install jq"
        echo "  CentOS: sudo yum install jq"
        echo ""
        exit 1
    fi

    # Check for python
    if ! command -v python &> /dev/null && ! command -v python3 &> /dev/null; then
        print_status ERROR "Python is not installed. Please install Python 3.8+ to continue."
        exit 1
    fi
}

create_backup() {
    local config_file=$1
    if [ -f "$config_file" ]; then
        local backup_file="${config_file}.backup.$(date +%Y%m%d_%H%M%S)"
        cp "$config_file" "$backup_file"
        if [ $? -eq 0 ]; then
            print_status INFO "Backup created: $backup_file"
            return 0
        else
            print_status ERROR "Failed to create backup"
            return 1
        fi
    fi
    return 0
}

merge_mcp_config() {
    local config_file=$1
    local config_dir=$(dirname "$config_file")

    # Create directory if it doesn't exist
    if [ ! -d "$config_dir" ]; then
        mkdir -p "$config_dir"
        print_status INFO "Created config directory: $config_dir"
    fi

    # Create backup if file exists
    create_backup "$config_file"
    if [ $? -ne 0 ]; then
        return 1
    fi

    # Define MCP server configuration
    local mcp_config=$(cat <<EOF
{
  "command": "python",
  "args": ["-m", "giljo_mcp.mcp_adapter"],
  "env": {
    "GILJO_SERVER_URL": "$GILJO_SERVER",
    "GILJO_API_KEY": "$GILJO_API_KEY"
  }
}
EOF
)

    # Merge configuration using jq
    if [ -f "$config_file" ]; then
        # File exists - merge with existing config
        local temp_file=$(mktemp)
        jq --argjson mcpConfig "$mcp_config" \
           '.mcpServers["giljo-mcp"] = $mcpConfig' \
           "$config_file" > "$temp_file"

        if [ $? -eq 0 ]; then
            mv "$temp_file" "$config_file"
            return 0
        else
            print_status ERROR "Failed to merge configuration"
            rm -f "$temp_file"
            return 1
        fi
    else
        # File doesn't exist - create new config
        echo "{\"mcpServers\": {\"giljo-mcp\": $mcp_config}}" | jq '.' > "$config_file"
        return $?
    fi
}

# ============================================================
# Configure Claude Code
# ============================================================
configure_claude() {
    local claude_config="$HOME/.claude.json"

    echo "  Configuring Claude Code..."

    if merge_mcp_config "$claude_config"; then
        print_status OK "Claude Code configured successfully"
        CLAUDE_CONFIGURED="1"
    else
        print_status ERROR "Failed to configure Claude Code"
    fi
}

# ============================================================
# Configure Cursor
# ============================================================
configure_cursor() {
    local cursor_config="$CURSOR_BASE/User/globalStorage/mcp.json"

    echo "  Configuring Cursor..."

    if merge_mcp_config "$cursor_config"; then
        print_status OK "Cursor configured successfully"
        CURSOR_CONFIGURED="1"
    else
        print_status ERROR "Failed to configure Cursor"
    fi
}

# ============================================================
# Configure Windsurf
# ============================================================
configure_windsurf() {
    local windsurf_config="$WINDSURF_BASE/config.json"

    echo "  Configuring Windsurf..."

    if merge_mcp_config "$windsurf_config"; then
        print_status OK "Windsurf configured successfully"
        WINDSURF_CONFIGURED="1"
    else
        print_status ERROR "Failed to configure Windsurf"
    fi
}

# ============================================================
# Main Script
# ============================================================

print_header "GiljoAI MCP - Tool Integration Installer"

echo "This script will detect your development tools and configure"
echo "them to use GiljoAI Agent Orchestration MCP Server."
echo ""
echo "Server: $GILJO_SERVER"
echo "User: $GILJO_USER"
echo "Organization: $GILJO_ORG"
echo "Platform: $OS_NAME"
echo ""
echo "The script will:"
echo "  1. Detect Claude Code, Cursor, and Windsurf installations"
echo "  2. Create backups of existing configurations"
echo "  3. Safely merge GiljoAI MCP server configuration"
echo "  4. Preserve all existing tool settings"
echo ""
read -p "Press Enter to continue..."

# Check dependencies
check_dependencies

print_header "Scanning for Development Tools..."

# Detect and Configure Claude Code
CLAUDE_CONFIG="$HOME/.claude.json"
if [ -f "$CLAUDE_CONFIG" ]; then
    print_status FOUND "Claude Code: $CLAUDE_CONFIG"
    configure_claude
else
    print_status SKIP "Claude Code not detected"
fi

# Detect and Configure Cursor
CURSOR_CONFIG="$CURSOR_BASE/User/globalStorage/mcp.json"
CURSOR_DIR="$CURSOR_BASE/User/globalStorage"
if [ -d "$CURSOR_BASE" ] || [ -f "$CURSOR_CONFIG" ]; then
    print_status FOUND "Cursor: $CURSOR_CONFIG"
    configure_cursor
else
    print_status SKIP "Cursor not detected"
fi

# Detect and Configure Windsurf
WINDSURF_CONFIG="$WINDSURF_BASE/config.json"
if [ -d "$WINDSURF_BASE" ] || [ -f "$WINDSURF_CONFIG" ]; then
    print_status FOUND "Windsurf: $WINDSURF_CONFIG"
    configure_windsurf
else
    print_status SKIP "Windsurf not detected"
fi

# ============================================================
# Configuration Summary
# ============================================================
print_header "Configuration Complete!"

TOOL_COUNT=0
if [ -n "$CLAUDE_CONFIGURED" ]; then
    echo -e "${GREEN}[OK]${NC} Claude Code configured successfully"
    ((TOOL_COUNT++))
fi
if [ -n "$CURSOR_CONFIGURED" ]; then
    echo -e "${GREEN}[OK]${NC} Cursor configured successfully"
    ((TOOL_COUNT++))
fi
if [ -n "$WINDSURF_CONFIGURED" ]; then
    echo -e "${GREEN}[OK]${NC} Windsurf configured successfully"
    ((TOOL_COUNT++))
fi

if [ $TOOL_COUNT -eq 0 ]; then
    echo ""
    print_status ERROR "No development tools were detected or configured."
    echo ""
    echo "Please ensure you have one of the following installed:"
    echo "  - Claude Code (AI CLI by Anthropic)"
    echo "  - Cursor (AI Code Editor)"
    echo "  - Windsurf (Codeium AI IDE)"
    echo ""
    echo "After installation, run this script again."
    exit 1
else
    echo ""
    echo "Successfully configured $TOOL_COUNT tool(s)."
    echo ""
    echo "Server: $GILJO_SERVER"
    echo "User: $GILJO_USER"
    echo ""
    echo "============================================================"
    echo "  IMPORTANT: Please restart your development tools"
    echo "  for the changes to take effect."
    echo "============================================================"
fi

echo ""
