# Production Environment Configuration - Dynamic LAN Deployment
# Leave VITE_API_URL empty to auto-detect from browser's hostname
# Updated: 2025-12-24

# API URL - leave empty for dynamic detection based on window.location.hostname
# VITE_API_URL=http://your-ip:7272
# VITE_WS_URL=ws://your-ip:7272

# Uncomment and set these only if you need a fixed endpoint:
# VITE_API_URL=http://192.168.1.132:7272
# VITE_WS_URL=ws://192.168.1.132:7272
