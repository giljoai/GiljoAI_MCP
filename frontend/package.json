{
  "name": "giljo-mcp-frontend",
  "version": "3.0.0",
  "description": "GiljoAI MCP Coding Orchestrator - Dashboard UI",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "analyze": "npm run build -- --mode analyze",
    "lint": "eslint src/ --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@mdi/font": "^7.3.0",
    "axios": "^1.6.0",
    "date-fns": "^3.0.0",
    "js-yaml": "^4.1.0",
    "lodash-es": "^4.17.21",
    "marked": "^17.0.0",
    "pinia": "^3.0.3",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0",
    "vuetify": "^3.4.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@eslint/js": "^9.0.0",
    "@pinia/testing": "^1.0.2",
    "@playwright/test": "^1.56.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.20.0",
    "globals": "^15.0.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.2.0",
    "sass-embedded": "^1.83.0",
    "vite": "^7.1.8",
    "vite-plugin-vuetify": "^2.1.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=8.0.0"
  }
}
