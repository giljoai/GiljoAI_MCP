# Docker build context ignore file for GiljoAI MCP
# This file reduces build context size and improves build performance

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/
htmlcov/
.tox/
.hypothesis/

# Virtual environments
venv/
ENV/
env/
.venv/
.virtualenv/

# Node modules and build artifacts
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# Git files
.git/
.gitignore
.gitattributes

# Documentation
*.md
!README.md
!CLAUDE.md
docs/
Docs/

# Test files and data
tests/
test_*.py
*_test.py
test_results.json
coverage.xml
*.log
logs/
temp/
backups/

# Database files (will be mounted as volumes)
data/
*.db
*.sqlite
*.sqlite3

# Environment and config files (will be mounted or passed as env vars)
.env
.env.*
!.env.example
*.env
config.local.yaml

# Docker files (not needed in build context)
docker-compose*.yml
Dockerfile*
.dockerignore

# CI/CD files
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Monitoring and benchmark scripts (not needed in container)
monitor*.py
benchmark*.py
*_monitor.py
*_benchmark.py

# MCP configuration (will be mounted)
.mcp.json
.mcp-serena.json

# Migrations (included selectively via COPY in Dockerfile)
!migrations/

# Keep important config files
!alembic.ini
!setup.py
!requirements.txt
!package.json
!package-lock.json