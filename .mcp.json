{
  "mcpServers": {
    "giljo-mcp": {
      "command": "python",
      "args": [
        "-m",
        "src.giljo_mcp.server"
      ],
      "env": {
        "PYTHONPATH": "F:\\GiljoAI_MCP\\src",
        "GILJO_MCP_DB": "F:\\GiljoAI_MCP\\data\\giljo_mcp.db",
        "ACTIVE_PRODUCT": "GiljoAI-MCP Coding Orchestrator"
      }
    },
    "serena-mcp": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena-mcp-server",
        "--context",
        "desktop-app",
        "--project",
        "F:\\GiljoAI_MCP"
      ]
    }
  }
}