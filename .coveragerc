[run]
# Coverage configuration for GiljoAI MCP project
source = src
branch = True
parallel = True
concurrency = thread,multiprocessing

# Exclude patterns - ignore test files, migrations, and generated code
omit = 
    */tests/*
    */test_*
    */__pycache__/*
    */migrations/*
    */venv/*
    */env/*
    */.venv/*
    setup.py
    */conftest.py
    */fixtures/*
    */helpers/*
    */mock_*
    temp/*
    logs/*
    data/*
    backups/*
    .coveragerc
    pyproject.toml

[report]
# Reporting options
precision = 2
show_missing = True
skip_covered = False
skip_empty = True
sort = Cover

# Exclude lines from coverage
exclude_lines =
    # Have to re-enable the standard pragma
    pragma: no cover
    
    # Don't complain about missing debug-only code:
    def __repr__
    if self\.debug
    
    # Don't complain if tests don't hit defensive assertion code:
    raise AssertionError
    raise NotImplementedError
    
    # Don't complain if non-runnable code isn't run:
    if 0:
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    
    # Don't complain about abstract methods
    @(abc\.)?abstractmethod
    
    # Don't complain about platform specific code
    if sys.platform
    
    # Don't complain about compatibility code
    except ImportError:

# Fail if coverage is below threshold
fail_under = 80

[html]
# HTML report options
directory = htmlcov
title = GiljoAI MCP Coverage Report

[xml]
# XML report for CI/CD integration
output = coverage.xml

[json]
# JSON report for programmatic analysis
output = coverage.json
pretty_print = true

[paths]
# Path mapping for consistent reporting across environments
source = 
    src/
    /app/src/
    C:\*\src\