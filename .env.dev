# GiljoAI MCP Development Environment Configuration
# This file is for local development with Docker Compose

# Database Configuration
DB_PASSWORD=dev_password_123
DB_HOST=postgres
DB_PORT=5432
DB_NAME=giljo_mcp_db
DB_USER=postgres

# Server Configuration
GILJO_MCP_MODE=local
GILJO_MCP_DASHBOARD_PORT=6000
GILJO_MCP_API_PORT=6002
GILJO_MCP_WEBSOCKET_PORT=6003

# Build Configuration
BUILD_TARGET=development

# API URLs for frontend
VITE_API_URL=http://localhost:6002
VITE_WS_URL=ws://localhost:6003

# Security (development defaults)
GILJO_MCP_API_KEY=
GILJO_MCP_SECRET_KEY=dev-secret-key-not-for-production

# Logging
LOG_LEVEL=DEBUG
DEBUG=true

# Development Features
HOT_RELOAD=true
ENABLE_SWAGGER=true
ENABLE_DEBUG_ENDPOINTS=true
ENABLE_PROFILING=true

# Feature Flags
ENABLE_VISION_CHUNKING=true
ENABLE_MULTI_TENANT=true
ENABLE_WEBSOCKET=true

# Session Settings
SESSION_TIMEOUT=3600
MAX_CONCURRENT_SESSIONS=10

# Agent Settings
MAX_AGENTS_PER_PROJECT=20
AGENT_CONTEXT_LIMIT=150000
AGENT_HANDOFF_THRESHOLD=140000

# Performance Settings (development)
WORKERS=1
WORKER_CONNECTIONS=100
KEEPALIVE=5
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=50
TIMEOUT=30