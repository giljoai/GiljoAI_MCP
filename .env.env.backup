# GiljoAI MCP Environment Configuration
# Copy this file to .env and update with your values
# NEVER commit .env to version control!

# Database Configuration (when using PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=giljo_mcp_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Server Configuration
# These override config.yaml settings
GILJO_MCP_MODE=local

# Port Configuration (avoids conflicts with AKE-MCP)
GILJO_MCP_DASHBOARD_PORT=6000
GILJO_MCP_SERVER_PORT=6001
GILJO_MCP_API_PORT=6002
GILJO_MCP_WEBSOCKET_PORT=6003

# Security (for LAN/WAN modes)
GILJO_MCP_API_KEY=
GILJO_MCP_SECRET_KEY=

# AKE-MCP Integration (during transition)
AKE_MCP_URL=http://localhost:5000
AKE_MCP_API_URL=http://localhost:5001

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/giljo_mcp.log

# Development Settings
DEBUG=true
HOT_RELOAD=true

# Feature Flags
ENABLE_VISION_CHUNKING=true
ENABLE_MULTI_TENANT=true
ENABLE_WEBSOCKET=true

# Session Settings
SESSION_TIMEOUT=3600
MAX_CONCURRENT_SESSIONS=10

# Agent Settings
MAX_AGENTS_PER_PROJECT=20
AGENT_CONTEXT_LIMIT=150000
AGENT_HANDOFF_THRESHOLD=140000

# Active Product (for MCP server context)
ACTIVE_PRODUCT=GiljoAI-MCP Coding Orchestrator
DATABASE_URL=sqlite:///F:/GiljoAI_MCP/data/giljo_mcp.db
DB_TYPE=sqlite