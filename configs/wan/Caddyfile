# Rate limiting configuration (requires caddy-ratelimit plugin)
# Install plugin: caddy add-package github.com/mholt/caddy-ratelimit
#
# (rate_limit_config) {
#     rate_limit {
#         zone api {
#             key {remote_host}
#             events 100
#             window 1m
#         }
#         zone auth {
#             key {remote_host}
#             events 5
#             window 1m
#         }
#         zone ws {
#             key {remote_host}
#             events 50
#             window 1m
#         }
#     }
# }
#
# Then import in each handle block:
# import rate_limit_config
