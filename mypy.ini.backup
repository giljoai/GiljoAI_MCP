[mypy]
# Global mypy configuration for GiljoAI MCP

# Python version
python_version = 3.9

# Import discovery
namespace_packages = True
explicit_package_bases = True
mypy_path = src

# Strict mode options (gradual enforcement)
strict_optional = True
warn_redundant_casts = True
warn_unused_ignores = True
warn_return_any = False  # Too noisy initially
warn_unreachable = True
no_implicit_optional = True
disallow_untyped_decorators = False  # Many decorators from libraries

# Error output
pretty = True
show_error_codes = True
show_error_context = True
show_column_numbers = True
error_summary = True

# Import handling
follow_imports = normal
ignore_missing_imports = False  # Will add per-module overrides
warn_no_return = True

# Miscellaneous strictness
allow_untyped_globals = False
allow_redefinition = False
local_partial_types = False
implicit_reexport = True
strict_equality = True

# Incremental checking
incremental = True
cache_dir = .mypy_cache

# Exclude patterns
exclude = (?x)(
    ^build/
    | ^dist/
    | ^\.venv/
    | ^venv/
    | ^node_modules/
    | ^migrations/
    | ^temp/
    | ^backups/
    | ^logs/
    | ^data/
    | ^\.serena/
    | ^\.giljo-config/
    | ^tests/fixtures/
    | ^installer/
    | ^installers/
    | bootstrap\.py$
    | setup\.py$
    | setup_gui\.py$
)

# Per-module options for third-party libraries without stubs
[mypy-fastmcp.*]
ignore_missing_imports = True

[mypy-uvicorn.*]
ignore_missing_imports = True

[mypy-passlib.*]
ignore_missing_imports = True

[mypy-jose.*]
ignore_missing_imports = True

[mypy-alembic.*]
ignore_missing_imports = True

[mypy-asyncpg.*]
ignore_missing_imports = True

[mypy-aiosqlite.*]
ignore_missing_imports = True

[mypy-websockets.*]
ignore_missing_imports = True

[mypy-rich.*]
ignore_missing_imports = True

[mypy-typer.*]
ignore_missing_imports = True

[mypy-pytest.*]
ignore_missing_imports = True

[mypy-pytest_asyncio.*]
ignore_missing_imports = True

[mypy-setuptools.*]
ignore_missing_imports = True

# Per-module options for test files (more lenient)
[mypy-tests.*]
disallow_untyped_defs = False
disallow_untyped_calls = False
disallow_incomplete_defs = False
check_untyped_defs = True
disallow_untyped_decorators = False
warn_return_any = False

[mypy-test_*]
disallow_untyped_defs = False
disallow_untyped_calls = False
disallow_incomplete_defs = False
check_untyped_defs = True
disallow_untyped_decorators = False
warn_return_any = False

# Per-module options for example files
[mypy-examples.*]
disallow_untyped_defs = False
disallow_untyped_calls = False
warn_return_any = False

# Installation files - bypass all type checking (transient code)
[mypy-bootstrap]
ignore_errors = True

[mypy-setup]
ignore_errors = True

[mypy-setup_gui]
ignore_errors = True

[mypy-installer.*]
ignore_errors = True

[mypy-installers.*]
ignore_errors = True

# Gradual typing for main application (start lenient)
[mypy-giljo_mcp.*]
disallow_untyped_defs = False  # Will enable gradually
disallow_untyped_calls = False  # Will enable gradually
disallow_incomplete_defs = True
check_untyped_defs = True